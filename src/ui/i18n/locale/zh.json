{
    "translation": {
        "common": {
            "error": "出错了：",
            "unexpected": "发生未知错误。"
        },
        "banner": {
            "prefix": "有什么可以效劳？按下",
            "suffix": "告诉我。"
        },
        "config": {
            "app": {
                "lang": {
                    "prompt": "选择您的语言:",
                    "options": {
                        "en": "English",
                        "zh": "简体中文"
                    }
                },
                "agentMode": {
                    "prompt": "使用什么模式？",
                    "options": {
                        "agent": "Agent (可以操作电脑，拥有完整权限)",
                        "plan": "Plan (只作规划，不实际操作电脑)",
                        "chat": "Chat (只聊天)"
                    }
                }
            },
            "env": {
                "hint": "您的环境配置不完整，Deepclaw将引导您完成配置，按回车继续...",
                "provider": {
                    "prompt": "请选择您的LLM接口类型：",
                    "options": {
                        "openai": "OpenAI",
                        "anthropic": "Anthropic"
                    }
                },
                "baseUrl": "请输入Base URL：",
                "apiKey": "请输入API key：",
                "model": "请输入模型名称：",
                "responseApi": {
                    "prompt": "是否使用OPENAI Response API?",
                    "options": {
                        "yes": "是",
                        "no": "否"
                    }
                }
            }
        },
        "agent": {
            "llm": {
                "openai": {
                    "response": {
                        "output": {
                            "failed": "出错了。{{message}}",
                            "error": "{{param}}出错了！错误码{{code}}：{{message}}。",
                            "empty": "没有收到回复。"
                        }
                    }
                }
            },
            "tools": {
                "permission": {
                    "request": "是否允许(y/n)："
                },
                "file": {
                    "guard": "Deepclaw想要访问当前工作区外的文件。",
                    "write": "写入文件{{path}}成功，共{{length}}字节。",
                    "edit": "编辑文件{{path}}成功。"
                },
                "shell": {
                    "guard": {
                        "danger": "禁止执行危险命令({{command}})。",
                        "warn": "检测到危险命令({{command}})。",
                        "mode": "Deepclaw未运行在agent模式，但模型想要运行shell命令({{command}})。"
                    },
                    "empty": "（无输出内容）",
                    "error": "出错了。{{message}}。",
                    "timeout": "命令运行{{timeout}}秒超时。"
                }
            }
        },
        "soup": [
            "每一次提问，都是向未知世界迈出的一步",
            "别急，慢慢想——好的答案，往往诞生于安静的时刻",
            "你的思考，比任何答案都更珍贵",
            "停下来，并非停顿，而是为下一个想法积蓄力量",
            "在你犹豫的时候，可能性正在悄悄生长",
            "问题越清晰，答案越靠近",
            "真正重要的不是我说什么，而是你想问什么",
            "耐心等待你的声音，就像等待一朵花慢慢打开",
            "勇敢说出你的疑惑吧，那里藏着成长的种子",
            "安静中，你与自己对话；然后，我们再开始",
            "每一次输入，都是你与这个世界更深的一次连接",
            "思考的空隙里，往往藏着最亮的灵感",
            "安静的片刻，是灵感最愿意停留的角落",
            "你的每一个问题，都是一粒种子——我会陪着它发芽",
            "别怕问得奇怪，最妙的答案往往藏在最怪的疑问里",
            "输入框里的空白，是未来的无限可能",
            "慢慢来，我不急——好的对话值得等待",
            "有时候，最好的回答就藏在你还没说出来的那句话里",
            "你思考的声音，我听得见",
            "停下来并不是中断，而是为了走得更深",
            "哪怕只是一个标点，我也会认真对待",
            "你愿意说，我就愿意听——没有期限",
            "不必一次说完，我们可以一句一句地靠近答案",
            "犹豫是思考的保护色，我会耐心等它褪去",
            "每一次等待，都是在为你让出更多思考的空间",
            "你的话语，无论长短，都是我想收到的礼物",
            "空白不是沉默，那是你在酝酿星星",
            "当你不知道从何说起，就从“我有一个问题……”开始吧",
            "我会一直在这里，像一本永远翻开的书，等着你写下第一行",
            "哪怕只是一声“嗨”，也是我们故事的序章",
            "你的每一次输入，都是对我最大的信任",
            "别担心问得太多——我的世界，因你的问题而精彩"
        ]
    }
}
